# Google OAuth (Web application) — redirect URI must be:
#   ${CALSYNC_PUBLIC_URL}/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of this app (no trailing slash). For local dev:
CALSYNC_PUBLIC_URL=http://localhost:3000

# Signed dashboard session cookie (required in production). Generate a long random string.
# CALSYNC_SESSION_SECRET=

# Optional: comma-separated Google emails allowed to sign in. If unset, any Google account can open the dashboard after OAuth.
# CALSYNC_ALLOWED_EMAILS=you@example.com

# Optional: Google Calendar push (events.watch) sends this on HTTPS URLs only.
# If set, webhook requests must include the same value in X-Goog-Channel-Token.
# CALSYNC_WEBHOOK_TOKEN=

# Optional: poll sync every N seconds while the Node server is running (e.g. 120).
# CALSYNC_AUTO_SYNC_INTERVAL_SEC=

# Optional: Bearer token for GET /api/cron/renew-watches (serverless push renewal).
# CALSYNC_CRON_SECRET=
